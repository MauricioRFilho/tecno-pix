APP_NAME=tecno-pix
APP_ENV=dev
APP_DEBUG=true
APP_PORT=9501

DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tecno_pix
DB_USERNAME=root
DB_PASSWORD=secret
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=
DB_WAIT_MAX_SECONDS=90
DB_POOL_MIN_CONNECTIONS=1
DB_POOL_MAX_CONNECTIONS=30
DB_POOL_WAIT_TIMEOUT=10

REDIS_HOST=redis
REDIS_AUTH=(null)
REDIS_PORT=6379
REDIS_DB=0

MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_MAILER=smtp
MAIL_ENCRYPTION=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@tecnopix.local
MAIL_FROM_NAME="Tecno Pix"
AUTO_DB_BOOTSTRAP=true

WITHDRAW_RATE_LIMIT_MAX=10
WITHDRAW_RATE_LIMIT_WINDOW_SECONDS=60
WITHDRAW_RATE_LIMIT_IN_TEST=false
WITHDRAW_PROCESS_MAX_CONCURRENCY=8
